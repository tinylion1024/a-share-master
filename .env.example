# Optional live credentials. The skill works without them in offline-first mode.
IWENCAI_BASE_URL=https://openapi.iwencai.com
IWENCAI_API_KEY=
MX_APIKEY=
EM_API_KEY=

# Offline-first controls
A_SHARE_SKILL_OFFLINE_MODE=true
A_SHARE_SKILL_DATA_PATH=
DATA_CACHE_DIR=/tmp/a_shares_cache
LOG_LEVEL=INFO

# Trading guardrails
MAX_POSITION_RATIO=0.5
MAX_SINGLE_POSITION=0.3
STOP_LOSS_RATIO=0.07
PROFIT_TARGET_MULTIPLIER=3
MIN_DAILY_TURNOVER_MILLION=50
